<div class="col">
  <div class="person-row">
    {% if project.img %}
      <div class="person-photo">
        <img src="{{ project.img | relative_url }}" alt="{{ project.title }}">
      </div>
    {% endif %}

    <div class="person-meta">
      <h4>{{ project.title }}</h4>

      {% if project.position %}
        <p class="person-position">{{ project.position }}</p>
      {% endif %}

      {% if project.email %}
        <p class="person-email">
          <a href="mailto:{{ project.email }}">{{ project.email }}</a>
        </p>
      {% endif %}

      {% if project.research %}
        <p class="person-research">{{ project.research }}</p>
      {% endif %}

      {% if project.department %}
        <p class="person-department">{{ project.department }}</p>
    </div>
  </div>
</div>